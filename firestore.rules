rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.role in ['superAdmin', 'manager', 'operations', 'contentEditor'];
    }

    function isSuperAdminOrManager() {
      return request.auth != null && request.auth.token.role in ['superAdmin', 'manager'];
    }

    function isSuperAdmin() {
      return request.auth != null && request.auth.token.role == 'superAdmin';
    }

    // Public read: site content
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /vehicles/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /destinations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blogPosts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin-only collections
    match /customers/{docId} {
      allow read, write: if isAdmin();
    }

    match /bookings/{docId} {
      allow read, write: if isAdmin();
    }

    match /pricingRules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promoCodes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /activityLogs/{docId} {
      allow read, write: if isAdmin();
    }

    // Contact forms & newsletter: writes handled by Cloud Functions (admin SDK);
    // admins can read/update via client.
    match /contactLeads/{docId} {
      allow read, update: if isAdmin();
    }

    match /complaints/{docId} {
      allow read, update: if isAdmin();
    }

    match /newsletterSubscribers/{docId} {
      allow read, write: if isAdmin();
    }

    // Admin profiles: Cloud Functions write; authenticated admins read own doc.
    match /admins/{docId} {
      allow read: if request.auth != null && request.auth.uid == docId;
      allow write: if false;
    }
  }
}
